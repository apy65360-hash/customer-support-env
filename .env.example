DATABASE_URL=sqlite:///./support.db
SECRET_KEY=changeme-replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Set to a real SMTP server for actual email delivery
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=support@example.com

# ── OpenEnv / Inference variables (required for inference.py) ─────────────────
# LLM inference endpoint (HuggingFace router or any OpenAI-compatible endpoint)
API_BASE_URL=https://router.huggingface.co/v1
# Model identifier to use for inference
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
# Your HuggingFace API key / token
HF_TOKEN=your-hf-token-here
